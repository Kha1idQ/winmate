<Page x:Class="WinMate.Views.Pages.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tweaks">
    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Tweaks_Title}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource Tweaks_Subtitle}" FontSize="14" Opacity="0.7" Margin="0,6,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="TweaksPanel" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
