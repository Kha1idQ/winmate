<Page x:Class="WinMate.Views.Pages.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:WinMate.Views.Controls"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Tweaks">
        <Grid Margin="40,28,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Context_Tweaks}"
                           Style="{StaticResource OverdriveContextLabelStyle}" />
                <TextBlock Text="{DynamicResource Tweaks_Title}"
                           Style="{StaticResource OverdrivePageTitleStyle}"
                                       Margin="0,8,0,0" />
                <TextBlock Text="{DynamicResource Tweaks_Subtitle}"
                           Style="{StaticResource OverdriveBodyStyle}"
                                       Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource SurfaceBrush}"
                            Padding="16,12"
                    VerticalAlignment="Bottom">
                <TextBlock Text="{DynamicResource Tweaks_StateStatus}"
                           Style="{StaticResource OverdriveMonoStyle}"
                           FontSize="10.5" />
            </Border>
        </Grid>

        <ui:TextBox x:Name="SearchBox"
                    Grid.Row="1"
                    Style="{StaticResource OverdriveTextBoxStyle}"
                                 Margin="0,24,12,12"
                    PlaceholderText="{DynamicResource Search_Tweaks}"
                    TextChanged="SearchBox_TextChanged" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <controls:TweakListControl x:Name="TweakList" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
