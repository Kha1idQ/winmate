<Page x:Class="WinMate.Views.Pages.GamingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:WinMate.Views.Controls"
      Title="Gaming">
    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Gaming_Title}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource GoldBrush}" />
                <TextBlock Text="{DynamicResource Gaming_Subtitle}" FontSize="14" Foreground="{DynamicResource GoldDimBrush}" Margin="0,6,0,0" />
            </StackPanel>
            <ui:Button x:Name="EnableAllButton"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Background="{DynamicResource GoldBrush}"
                       BorderBrush="{DynamicResource GoldBrush}"
                       Foreground="{DynamicResource ApplicationBackgroundBrush}"
                       Icon="{ui:SymbolIcon Rocket24}"
                       Content="{DynamicResource Gaming_EnableAll}"
                       Click="EnableAllButton_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <controls:TweakListControl x:Name="TweakList" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
