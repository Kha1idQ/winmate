<Page x:Class="WinMate.Views.Pages.GamingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:WinMate.Views.Controls"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Gaming">
        <Grid Margin="40,28,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,12,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Context_Gaming}"
                           Style="{StaticResource OverdriveContextLabelStyle}" />
                <TextBlock Text="{DynamicResource Gaming_Title}"
                           Style="{StaticResource OverdrivePageTitleStyle}"
                                       Margin="0,8,0,0" />
                <TextBlock Text="{DynamicResource Gaming_Subtitle}"
                           Style="{StaticResource OverdriveBodyStyle}"
                                       Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <TextBlock Text="{DynamicResource Gaming_MissionStatus}"
                           Style="{StaticResource OverdriveMonoStyle}"
                           HorizontalAlignment="Right"
                           Margin="0,0,0,8" />
                <ui:Button x:Name="EnableAllButton"
                           Style="{StaticResource OverdrivePrimaryButtonStyle}"
                           Content="{DynamicResource Gaming_EnableAll}"
                           Click="EnableAllButton_Click" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <controls:TweakListControl x:Name="TweakList" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
