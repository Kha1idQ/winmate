<Page x:Class="WinMate.Views.Pages.AppsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Apps">
    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Apps_Title}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource Apps_Subtitle}" FontSize="14" Opacity="0.7" Margin="0,6,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CatalogPanel" Margin="0,0,12,0" />
        </ScrollViewer>

        <ui:Button x:Name="InstallButton"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   HorizontalAlignment="Stretch"
                   Appearance="Primary"
                   Icon="{ui:SymbolIcon ArrowDownload24}"
                   IsEnabled="False"
                   Click="InstallButton_Click" />
    </Grid>
</Page>
