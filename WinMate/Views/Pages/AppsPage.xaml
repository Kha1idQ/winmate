<Page x:Class="WinMate.Views.Pages.AppsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Apps">
    <Grid Margin="48,32,48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource Apps_Title}" FontSize="36" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="{DynamicResource Apps_Subtitle}" FontSize="15"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,20,12,0">
            <TextBlock Text="{DynamicResource Apps_BundlesLabel}" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" />
            <WrapPanel x:Name="BundlesPanel" />
        </StackPanel>

        <ui:TextBox x:Name="SearchBox"
                    Grid.Row="2"
                    Height="48"
                    Margin="0,18,12,16"
                    FontSize="14"
                    PlaceholderText="{DynamicResource Search_Apps}"
                    TextChanged="SearchBox_TextChanged" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="0,2,0,0">
            <StackPanel x:Name="CatalogPanel" Margin="0,0,12,0" />
        </ScrollViewer>

        <ui:Button x:Name="InstallButton"
                   Grid.Row="4"
                   Height="50"
                   Margin="0,16,12,0"
                   HorizontalAlignment="Stretch"
                   FontSize="15"
                   BorderThickness="0"
                   Background="{DynamicResource PrimaryButtonBrush}"
                   Foreground="{DynamicResource OnPrimaryBrush}"
                   IsEnabled="False"
                   Click="InstallButton_Click" />
    </Grid>
</Page>
