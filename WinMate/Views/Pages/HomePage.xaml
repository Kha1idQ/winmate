<Page x:Class="WinMate.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home">
    <StackPanel Margin="32">
        <TextBlock Text="{DynamicResource Home_Title}" FontSize="28" FontWeight="SemiBold" />
        <TextBlock Text="{DynamicResource Home_Subtitle}" FontSize="14" Opacity="0.7" Margin="0,8,0,0" />
    </StackPanel>
</Page>
