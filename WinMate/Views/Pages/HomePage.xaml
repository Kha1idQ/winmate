<Page x:Class="WinMate.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Home">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,32,48,24">
            <TextBlock Text="{DynamicResource Home_Title}" FontSize="36" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="{DynamicResource Home_Subtitle}" FontSize="15"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" />

            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                <ui:Button x:Name="RestoreButton"
                           Height="44" Padding="18,0,18,0"
                           Content="{DynamicResource Home_RestoreButton}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Click="RestoreButton_Click" />
                <ui:Button x:Name="ResetButton"
                           Height="44" Padding="18,0,18,0"
                           Margin="12,0,0,0"
                           Content="{DynamicResource Home_ResetButton}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Click="ResetButton_Click" />
            </StackPanel>

            <TextBlock Text="{DynamicResource Home_ProfilesTitle}"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,36,0,6" />
            <TextBlock Text="{DynamicResource Home_ProfilesSubtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,18" />

            <ItemsControl x:Name="ProfilesPanel" />
        </StackPanel>
    </ScrollViewer>
</Page>
