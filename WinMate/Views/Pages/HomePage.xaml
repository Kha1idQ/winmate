<Page x:Class="WinMate.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Home">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,16">
            <TextBlock Text="{DynamicResource Home_Title}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource GoldBrush}" />
            <TextBlock Text="{DynamicResource Home_Subtitle}" FontSize="14" Foreground="{DynamicResource GoldDimBrush}" Margin="0,8,0,0" />

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <ui:Button x:Name="RestoreButton"
                           Content="{DynamicResource Home_RestoreButton}"
                           Icon="{ui:SymbolIcon Shield24}"
                           Click="RestoreButton_Click" />
                <ui:Button x:Name="ResetButton"
                           Margin="10,0,0,0"
                           Content="{DynamicResource Home_ResetButton}"
                           Icon="{ui:SymbolIcon ArrowUndo24}"
                           Click="ResetButton_Click" />
            </StackPanel>

            <TextBlock Text="{DynamicResource Home_ProfilesTitle}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource GoldBrush}"
                       Margin="0,28,0,4" />
            <TextBlock Text="{DynamicResource Home_ProfilesSubtitle}"
                       FontSize="12" Foreground="{DynamicResource GoldDimBrush}"
                       Margin="0,0,0,12" />

            <ItemsControl x:Name="ProfilesPanel" />

            <TextBlock x:Name="VersionText"
                       Margin="0,16,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource GoldDimBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
