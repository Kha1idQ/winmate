<Page x:Class="WinMate.Views.Pages.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Manager">
    <Grid Margin="48,32,48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Manager_Title}" FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock x:Name="StatsText" FontSize="15" Margin="0,8,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button x:Name="RefreshButton"
                           Height="48" Padding="16,0,16,0" FontSize="15"
                           Content="{DynamicResource Manager_Refresh}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="UpdateAllButton"
                           Height="48" Padding="20,0,20,0" FontSize="15"
                           Margin="12,0,0,0"
                           BorderThickness="0"
                           Background="{DynamicResource PrimaryButtonBrush}"
                           Foreground="{DynamicResource OnPrimaryBrush}"
                           IsEnabled="False"
                           Click="UpdateAllButton_Click" />
            </StackPanel>
        </Grid>

        <ui:TextBox x:Name="SearchBox"
                    Grid.Row="1"
                    Height="48"
                    Margin="0,20,12,10"
                    FontSize="14"
                    PlaceholderText="{DynamicResource Search_Manager}"
                    TextChanged="SearchBox_TextChanged" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ListPanel" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
