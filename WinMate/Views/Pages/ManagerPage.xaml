<Page x:Class="WinMate.Views.Pages.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="{DynamicResource AppBackgroundBrush}"
      Title="Manager">
        <Grid Margin="40,28,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Context_Manager}"
                           Style="{StaticResource OverdriveContextLabelStyle}" />
                <TextBlock Text="{DynamicResource Manager_Title}"
                           Style="{StaticResource OverdrivePageTitleStyle}"
                                       Margin="0,8,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{DynamicResource SuccessBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatsText"
                               Style="{StaticResource OverdriveMonoStyle}"
                                           Margin="8,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <ui:Button x:Name="RefreshButton"
                           Style="{StaticResource OverdriveSecondaryButtonStyle}"
                           Content="{DynamicResource Manager_Refresh}"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="UpdateAllButton"
                           Style="{StaticResource OverdrivePrimaryButtonStyle}"
                                    Margin="12,0,0,0"
                           Content="{DynamicResource Manager_UpdateAll}"
                           IsEnabled="False"
                           Click="UpdateAllButton_Click" />
            </StackPanel>
        </Grid>

        <ui:TextBox x:Name="SearchBox"
                    Grid.Row="1"
                    Style="{StaticResource OverdriveTextBoxStyle}"
                                 Margin="0,24,12,12"
                    PlaceholderText="{DynamicResource Search_Manager}"
                    TextChanged="SearchBox_TextChanged" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ListPanel" Margin="0,0,12,0" />
        </ScrollViewer>
    </Grid>
</Page>
