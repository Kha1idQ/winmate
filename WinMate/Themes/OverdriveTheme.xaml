<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- WinMate theme resources: fonts, type scale, brushes and control styles.
         ThemeService swaps the brush colours at runtime for the two palettes. -->
    <FontFamily x:Key="DisplayFont">Bahnschrift SemiCondensed, Bahnschrift, Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Cascadia Code, Consolas</FontFamily>

    <sys:Double x:Key="TextXs">10</sys:Double>
    <sys:Double x:Key="TextSm">12.5</sys:Double>
    <sys:Double x:Key="TextBase">15</sys:Double>
    <sys:Double x:Key="TextMd">19</sys:Double>
    <sys:Double x:Key="TextLg">24</sys:Double>
    <sys:Double x:Key="TextXl">31</sys:Double>
    <sys:Double x:Key="TextDisplay">52</sys:Double>

    <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="OverdriveCornerRadius">0</CornerRadius>

    <!-- Seed values. ThemeService mutates these brushes in place. -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0907" />
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#0B0907" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#0A0806" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#120F0B" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#17130D" />
    <SolidColorBrush x:Key="NavActiveBrush" Color="#211809" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3022" />
    <SolidColorBrush x:Key="CardBorderStrongBrush" Color="#685333" />
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2EEE5" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A39886" />
    <SolidColorBrush x:Key="TextQuietBrush" Color="#756C5E" />
    <SolidColorBrush x:Key="DisabledBrush" Color="#625A4C" />

    <SolidColorBrush x:Key="AccentBrush" Color="#F2A514" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#D98E08" />
    <SolidColorBrush x:Key="AccentAltBrush" Color="#D5B56A" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#78CF82" />
    <SolidColorBrush x:Key="WarningBrush" Color="#E7B95F" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#E06A54" />
    <SolidColorBrush x:Key="FocusBrush" Color="#FFD166" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#211506" />
    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#F2A514" />

    <SolidColorBrush x:Key="AccentTintBrush" Color="#24F2A514" />
    <SolidColorBrush x:Key="AccentAltTintBrush" Color="#20D5B56A" />
    <SolidColorBrush x:Key="SuccessTintBrush" Color="#2078CF82" />
    <SolidColorBrush x:Key="WarningTintBrush" Color="#24E7B95F" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="#A6F2A514" />
    <SolidColorBrush x:Key="AccentAltBorderBrush" Color="#80D5B56A" />
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="#8078CF82" />
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#8FE7B95F" />

    <Style x:Key="OverdriveFocusVisualStyle">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource FocusBrush}"
                            BorderThickness="2"
                            Margin="-3"
                            SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OverdriveContextLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="OverdrivePageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}" />
        <Setter Property="FontSize" Value="38" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="40" />
    </Style>

    <Style x:Key="OverdriveDisplayTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}" />
        <Setter Property="FontSize" Value="54" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="56" />
    </Style>

    <Style x:Key="OverdriveSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="OverdriveBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="23" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="OverdriveMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="OverdrivePrimaryButtonStyle"
           TargetType="{x:Type ui:Button}"
           BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource OverdriveFocusVisualStyle}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.52" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverdriveSecondaryButtonStyle"
           TargetType="{x:Type ui:Button}"
           BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource OverdriveFocusVisualStyle}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderStrongBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavActiveBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.52" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverdriveIconButtonStyle"
           TargetType="{x:Type ui:Button}"
           BasedOn="{StaticResource OverdriveSecondaryButtonStyle}">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="OverdriveTextBoxStyle"
           TargetType="{x:Type ui:TextBox}"
           BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource OverdriveFocusVisualStyle}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.52" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
