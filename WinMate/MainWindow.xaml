<ui:FluentWindow x:Class="WinMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:WinMate.Views.Pages"
        Title="WinMate"
        Width="1050" Height="680"
        WindowBackdropType="None"
        Background="#1B1916"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource App_Title}"
                     Foreground="{DynamicResource GoldBrush}">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Wrench24" Foreground="{DynamicResource GoldBrush}" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <ui:Button x:Name="LangButton"
                           Content="{DynamicResource Lang_Toggle}"
                           Icon="{ui:SymbolIcon LocalLanguage24}"
                           Appearance="Secondary"
                           Foreground="{DynamicResource GoldBrush}"
                           Margin="0,0,6,0"
                           Click="LangButton_Click" />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           OpenPaneLength="200"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{DynamicResource Nav_Home}" TargetPageType="{x:Type pages:HomePage}"
                                       Foreground="{DynamicResource GoldBrush}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" Foreground="{DynamicResource GoldBrush}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{DynamicResource Nav_Apps}" TargetPageType="{x:Type pages:AppsPage}"
                                       Foreground="{DynamicResource GoldBrush}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="AppsAddIn24" Foreground="{DynamicResource GoldBrush}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{DynamicResource Nav_Tweaks}" TargetPageType="{x:Type pages:TweaksPage}"
                                       Foreground="{DynamicResource GoldBrush}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Options24" Foreground="{DynamicResource GoldBrush}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{DynamicResource Nav_Gaming}" TargetPageType="{x:Type pages:GamingPage}"
                                       Foreground="{DynamicResource GoldBrush}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="XboxController24" Foreground="{DynamicResource GoldBrush}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <Expander x:Name="LogExpander"
                  Grid.Row="2"
                  Header="{DynamicResource Log_Title}"
                  IsExpanded="False"
                  Background="#1B1916"
                  BorderBrush="#463C1F"
                  Foreground="{DynamicResource GoldBrush}"
                  Margin="12,0,12,8">
            <TextBox x:Name="LogBox"
                     Height="150"
                     Margin="0,6,0,0"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#1B1916"
                     Foreground="{DynamicResource GoldBrush}"
                     BorderBrush="#463C1F"
                     CaretBrush="{DynamicResource GoldBrush}"
                     FlowDirection="LeftToRight"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </Expander>
    </Grid>
</ui:FluentWindow>
