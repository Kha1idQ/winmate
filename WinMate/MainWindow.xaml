<ui:FluentWindow x:Class="WinMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:WinMate.Views.Pages"
        Title="WinMate"
        Width="1260" Height="800"
        MinWidth="940" MinHeight="640"
        FontFamily="{DynamicResource BodyFont}"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="DoNotRound"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title=""
                     VerticalAlignment="Stretch"
                     Background="{DynamicResource SidebarBrush}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Grid Width="54" Height="54" FlowDirection="LeftToRight">
                        <Border Width="38" Height="38"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="2"
                                Background="Transparent"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>
                        <ContentControl x:Name="LogoMark"
                                        Width="23" Height="23"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="WINMATE / OVERDRIVE"
                               FontFamily="{DynamicResource DisplayFont}"
                               FontSize="18"
                               FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FlowDirection="LeftToRight" />
                </StackPanel>
            </ui:TitleBar.Header>

            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <ui:Button x:Name="LangButton"
                               Style="{StaticResource OverdriveSecondaryButtonStyle}"
                               Content="{DynamicResource Lang_Toggle}"
                               MinWidth="112"
                               Click="LangButton_Click" />
                    <ui:Button x:Name="ThemeButton"
                               Style="{StaticResource OverdriveIconButtonStyle}"
                               Content="••"
                               FontSize="17"
                               Margin="8,0,0,0"
                               ToolTip="{DynamicResource Theme_Toggle}"
                               Click="ThemeButton_Click" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Border Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SidebarBrush}"
                                Padding="12,8"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                <Ellipse Width="8" Height="8"
                         Fill="{DynamicResource SuccessBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource Shell_SystemStable}"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="12,0,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Text=" / LOCAL "
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource TextQuietBrush}"
                                       Margin="12,0,0,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="ClockText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ui:NavigationView x:Name="RootNavigation"
                               PaneDisplayMode="Left"
                               OpenPaneLength="108"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="False">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="NavHome" Height="76" Margin="0,0,8,0" TargetPageType="{x:Type pages:HomePage}" />
                    <ui:NavigationViewItem x:Name="NavApps" Height="76" Margin="0,0,8,0" TargetPageType="{x:Type pages:AppsPage}" />
                    <ui:NavigationViewItem x:Name="NavManager" Height="76" Margin="0,0,8,0" TargetPageType="{x:Type pages:ManagerPage}" />
                    <ui:NavigationViewItem x:Name="NavTweaks" Height="76" Margin="0,0,8,0" TargetPageType="{x:Type pages:TweaksPage}" />
                    <ui:NavigationViewItem x:Name="NavGaming" Height="76" Margin="0,0,8,0" TargetPageType="{x:Type pages:GamingPage}" />
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.PaneFooter>
                    <Border BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="12,8,12,4"
                            Padding="0,12,0,8">
                        <TextBlock x:Name="VersionText"
                                   HorizontalAlignment="Center"
                                   FontSize="10"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FlowDirection="LeftToRight"
                                   Foreground="{DynamicResource TextQuietBrush}" />
                    </Border>
                </ui:NavigationView.PaneFooter>
            </ui:NavigationView>

            <Rectangle Width="1"
                       HorizontalAlignment="Left"
                       Margin="108,0,0,0"
                       Fill="{DynamicResource CardBorderBrush}"
                       IsHitTestVisible="False" />
        </Grid>

        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}">
            <Expander x:Name="LogExpander"
                      IsExpanded="False"
                      Background="Transparent"
                      BorderThickness="0"
                        Padding="16,2,16,2">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                        <Ellipse Width="8" Height="8"
                                 Fill="{DynamicResource SuccessBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Log_Title}"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                        <TextBlock Text="{DynamicResource Shell_NoPending}"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextQuietBrush}"
                                   VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                    </StackPanel>
                </Expander.Header>
                <TextBox x:Name="LogBox"
                         Height="170"
                                 Margin="0,8,0,8"
                         IsReadOnly="True"
                         FontFamily="{DynamicResource MonoFont}"
                         FontSize="12"
                         Background="{DynamicResource AppBackgroundBrush}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         BorderThickness="1"
                         CaretBrush="{DynamicResource AccentBrush}"
                         FlowDirection="LeftToRight"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Expander>
        </Border>
    </Grid>
</ui:FluentWindow>
