<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <sys:String x:Key="App_Title">WinMate</sys:String>
    <sys:String x:Key="Lang_Toggle">عربي</sys:String>
    <sys:String x:Key="Theme_Toggle">Switch theme (blue / gold)</sys:String>

    <sys:String x:Key="Nav_Home">Home</sys:String>
    <sys:String x:Key="Nav_Apps">Apps</sys:String>
    <sys:String x:Key="Nav_Tweaks">Tweaks</sys:String>
    <sys:String x:Key="Nav_Gaming">Gaming</sys:String>

    <sys:String x:Key="Home_Title">Home</sys:String>
    <sys:String x:Key="Home_Subtitle">Welcome to WinMate — set up, clean up, and speed up Windows</sys:String>
    <sys:String x:Key="Home_ProfilesTitle">One-click profiles</sys:String>
    <sys:String x:Key="Home_ProfilesSubtitle">Apply a whole set of tweaks at once — everything stays reversible from the Tweaks tab</sys:String>
    <sys:String x:Key="Home_ProfileApply">Apply</sys:String>
    <sys:String x:Key="Home_ProfileTweakCount">tweaks</sys:String>
    <sys:String x:Key="Home_ProfileConfirmBody">This will apply the following tweaks (any already on will be skipped):</sys:String>
    <sys:String x:Key="Home_ProfileConfirmYes">Apply profile</sys:String>
    <sys:String x:Key="Home_ProfileApplied">applied</sys:String>
    <sys:String x:Key="Home_ProfileAlreadyOn">already on</sys:String>
    <sys:String x:Key="Home_ProfileFailed">failed</sys:String>
    <sys:String x:Key="Home_ToolsTitle">Tools</sys:String>
    <sys:String x:Key="Home_ResetButton">Reset all tweaks</sys:String>
    <sys:String x:Key="Home_ResetConfirmBody">This undoes every tweak you've applied and returns those settings to Windows defaults. One-shot actions (debloat, temp clean) can't be undone. Continue?</sys:String>
    <sys:String x:Key="Home_ResetConfirmYes">Reset everything</sys:String>
    <sys:String x:Key="Home_ResetUndone">tweaks reverted</sys:String>

    <sys:String x:Key="Apps_Title">Apps</sys:String>
    <sys:String x:Key="Apps_Subtitle">Install your favorite apps with one click</sys:String>
    <sys:String x:Key="Apps_InstallSelected">Install selected</sys:String>
    <sys:String x:Key="Apps_BundlesLabel">Quick bundles — click to select a set, then install</sys:String>
    <sys:String x:Key="Apps_Installed">Installed</sys:String>
    <sys:String x:Key="Apps_LogInstalling">Installing</sys:String>
    <sys:String x:Key="Apps_LogDone">installed successfully</sys:String>
    <sys:String x:Key="Apps_LogFailed">failed</sys:String>
    <sys:String x:Key="Apps_LogFailedSummary">Failed apps</sys:String>
    <sys:String x:Key="Log_Title">Live log</sys:String>
    <sys:String x:Key="Search_Apps">Search apps...</sys:String>
    <sys:String x:Key="Search_Tweaks">Search tweaks...</sys:String>
    <sys:String x:Key="Chip_RestartRequired">Restart required</sys:String>
    <sys:String x:Key="Chip_Advanced">Advanced</sys:String>
    <sys:String x:Key="Cat_browsers">Browsers</sys:String>
    <sys:String x:Key="Cat_dev">Developer tools</sys:String>
    <sys:String x:Key="Cat_gaming">Gaming</sys:String>
    <sys:String x:Key="Cat_media">Media</sys:String>
    <sys:String x:Key="Cat_utils">Utilities</sys:String>

    <sys:String x:Key="Tweaks_Title">Tweaks</sys:String>
    <sys:String x:Key="Tweaks_Subtitle">Clean up and speed up Windows — every switch can be turned back off</sys:String>
    <sys:String x:Key="TweakCat_explorer">Explorer &amp; taskbar</sys:String>
    <sys:String x:Key="TweakCat_privacy">Privacy</sys:String>
    <sys:String x:Key="Tweaks_LogApplying">Applying</sys:String>
    <sys:String x:Key="Tweaks_LogUndoing">Undoing</sys:String>
    <sys:String x:Key="TweakCat_performance">Performance</sys:String>
    <sys:String x:Key="TweakCat_cleanup">Cleanup &amp; debloat</sys:String>
    <sys:String x:Key="Tweaks_Run">Run</sys:String>
    <sys:String x:Key="Tweaks_Confirm">Yes, run it</sys:String>
    <sys:String x:Key="Tweaks_Cancel">Cancel</sys:String>
    <sys:String x:Key="Tweaks_ConfirmIrreversible">⚠ This action cannot be undone.</sys:String>
    <sys:String x:Key="Home_RestoreButton">Create restore point</sys:String>
    <sys:String x:Key="Restore_Title">Create a restore point?</sys:String>
    <sys:String x:Key="Restore_Body">Before changing Windows settings, WinMate can create a system restore point so you can roll everything back if needed. Recommended.</sys:String>
    <sys:String x:Key="Restore_Yes">Create restore point</sys:String>
    <sys:String x:Key="Restore_No">Skip</sys:String>
    <sys:String x:Key="Restore_Creating">Creating system restore point (takes ~30 seconds)...</sys:String>
    <sys:String x:Key="Restore_Done">✓ Restore point created</sys:String>
    <sys:String x:Key="Restore_Skipped24h">Windows skipped it — a restore point from the last 24 hours already exists</sys:String>

    <sys:String x:Key="Gaming_Title">Gaming</sys:String>
    <sys:String x:Key="Gaming_Subtitle">Optimize Windows for gaming</sys:String>
    <sys:String x:Key="Gaming_EnableAll">Enable all gaming tweaks</sys:String>
    <sys:String x:Key="Tweaks_RestartNeeded">⟳ Restart your PC for this change to take effect</sys:String>

</ResourceDictionary>
